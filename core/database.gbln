/// glams/graveyard/database.gbln

act select(table)
    return :need("select", table, {})
xx

act select(table, opts)
    return :need("select", table, opts)
xx

act insert(table, data)
    return :need("insert", table, data)
xx

act update(table, filters, data)
    return :need("update", table, filters, data)
xx

act delete(table, filters)
    return :need("delete", table, filters)
xx